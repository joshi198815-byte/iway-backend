{
  "name": "iway-backend",
  "version": "1.0.0",
  "description": "Backend base para iway con NestJS + Prisma",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "sh ./scripts/docker-entrypoint.sh",
    "start:dev": "ts-node --transpile-only src/main.ts",
    "start:local": "node scripts/start-local.js",
    "build": "npm run prisma:generate:postgres && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:push:skip-generate": "prisma db push --skip-generate",
    "start:prod": "node dist/src/main.js",
    "postinstall": "npm run prisma:generate:postgres",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:validate:postgres": "prisma validate --schema prisma/schema.postgres.prisma",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:apply:production": "sh ./scripts/apply_postgres_schema.sh .env.production",
    "db:apply:staging": "sh ./scripts/apply_postgres_schema.sh .env.staging",
    "seed:staging": "npx ts-node prisma/seed.staging.ts",
    "backup:uploads": "sh ./scripts/backup_uploads.sh",
    "restore:uploads": "sh ./scripts/restore_uploads.sh",
    "health:external": "sh ./scripts/check_external_health.sh",
    "deploy:check-env": "sh ./scripts/validate_production_env.sh .env.production",
    "deploy:smoke": "sh ./scripts/smoke_deploy.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.18",
    "@prisma/client": "^6.16.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "embedded-postgres": "^18.3.0-beta.16",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/websockets": "^11.1.18",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^6.16.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
