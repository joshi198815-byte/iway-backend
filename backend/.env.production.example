PORT=10000
NODE_ENV=production

# Render PostgreSQL connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Security
JWT_SECRET="replace-with-long-random-secret-at-least-32-chars"

# Google Maps / Places API
MAPS_API_KEY=""

# Firebase Admin SDK
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Render tip: keep escaped newlines in one line
FIREBASE_PRIVATE_KEY=""

# Public URLs
APP_BASE_URL="https://api.iway.one"
FRONTEND_URL="https://admin.iway.one"

# Storage / backups / observability
STORAGE_MODE="local-disk"
UPLOADS_DIR="./uploads"
STORAGE_PROTECTED_BASE_URL="/api/storage/file"
BACKUP_RETENTION_DAYS=7
OBSERVABILITY_ALERT_WEBHOOK_URL=""
OBSERVABILITY_ALERT_COOLDOWN_MS=120000

# Optional one-time bootstrap for first production admin
INITIAL_ADMIN_EMAIL=""
INITIAL_ADMIN_PASSWORD=""
INITIAL_ADMIN_FULL_NAME=""
INITIAL_ADMIN_PHONE=""
INITIAL_ADMIN_COUNTRY_CODE="GT"
