# Backend local / Render example
PORT=3000
NODE_ENV=production

# Render PostgreSQL / Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Auth
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Google Maps / Places API
# The mobile app uses this key for address autocomplete and maps.
MAPS_API_KEY=""

# Firebase Admin SDK for push notifications
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# In Render, paste the private key with escaped newlines: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY=""

# Public app/backend URLs and CORS
APP_BASE_URL="https://api.example.com"
CORS_ORIGIN="https://admin.example.com"
# Optional multi-origin override:
# CORS_ORIGINS="https://app.example.com,https://admin.example.com"

# Optional storage/runtime knobs
STORAGE_MODE="local-disk"
UPLOADS_DIR="./uploads"
STORAGE_PROTECTED_BASE_URL="/api/storage/file"
BACKUP_RETENTION_DAYS=7
OBSERVABILITY_ALERT_WEBHOOK_URL=""
OBSERVABILITY_ALERT_COOLDOWN_MS=120000

# Optional one-time production admin bootstrap
INITIAL_ADMIN_EMAIL=""
INITIAL_ADMIN_PASSWORD=""
INITIAL_ADMIN_FULL_NAME=""
INITIAL_ADMIN_PHONE=""
INITIAL_ADMIN_COUNTRY_CODE="GT"
